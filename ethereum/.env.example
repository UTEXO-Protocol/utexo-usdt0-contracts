# RPC endpoint of the source chain where you are deploying
RPC_URL=

# Deployer private key
PRIVATE_KEY=

# ERC-20 token pulled from users.
# On Ethereum: canonical USDT address.
# On chains where USDT0 is the native token: USDT0 token address (often same as OFT_ADDRESS).
TOKEN_ADDRESS=

# USDT0 OFT (adapter or native OFT) deployed on this source chain.
OFT_ADDRESS=

# LayerZero V2 endpoint id of the destination chain.
# Arbitrum One = 30110
DST_EID=30110

# BridgeComposer contract address on the destination chain, encoded as bytes32.
# Left-pad the 20-byte address with zeros:
#   e.g. 0x000000000000000000000000<BridgeComposer_address_without_0x>
BRIDGE_COMPOSER=
